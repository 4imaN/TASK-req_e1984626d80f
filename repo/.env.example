DATABASE_URL=postgresql+asyncpg://trailgoods:trailgoods@localhost:5432/trailgoods
DATABASE_URL_SYNC=postgresql+psycopg://trailgoods:trailgoods@localhost:5432/trailgoods
TEST_DATABASE_URL=postgresql+asyncpg://trailgoods:trailgoods@localhost:5432/trailgoods_test
TEST_DATABASE_URL_SYNC=postgresql+psycopg://trailgoods:trailgoods@localhost:5432/trailgoods_test

SECRET_KEY=change-me-to-a-random-64-char-hex-string
ENCRYPTION_MASTER_KEY_FILE=/run/secrets/master.key

ASSET_STORAGE_ROOT=/data/assets
BACKUP_STORAGE_ROOT=/data/backups
PREVIEW_STORAGE_ROOT=/data/previews

LOG_LEVEL=INFO
WORKER_POLL_INTERVAL_SECONDS=5
SESSION_IDLE_TIMEOUT_MINUTES=30
FAILED_LOGIN_WINDOW_MINUTES=15
FAILED_LOGIN_MAX_ATTEMPTS=5
CHALLENGE_LOCKOUT_MINUTES=15
PASSWORD_HISTORY_COUNT=5
